config INPUT_IQS9151_DRAG_LOCK_ENABLE
    bool "IQS9151 drag lock enable"
    default n
    depends on INPUT_IQS9151_1F_PRESSHOLD_ENABLE || \
               INPUT_IQS9151_2F_PRESSHOLD_ENABLE || \
               INPUT_IQS9151_3F_PRESSHOLD_ENABLE
    help
      Enable macOS-style drag lock for TapDrag gestures.
      When a TapDrag (tap -> tap-and-hold -> drag) lift occurs, the
      currently held button (BTN_0 for 1F, BTN_1 for 2F, BTN_2 for 3F)
      is kept pressed instead of being released. The lock is released
      by a subsequent 1F single tap. Defaults to n to preserve existing
      behavior.

config INPUT_IQS9151_DRAG_LOCK_RELEASE_TAP_MAX_MS
    int "IQS9151 drag lock release-tap max time (ms)"
    range 1 1000
    default 250
    depends on INPUT_IQS9151_DRAG_LOCK_ENABLE
    help
      Maximum down duration for the 1F single-tap that releases an
      active drag lock.

config INPUT_IQS9151_DRAG_LOCK_RELEASE_TAP_MOVE
    int "IQS9151 drag lock release-tap move threshold"
    range 1 1000
    default 50
    depends on INPUT_IQS9151_DRAG_LOCK_ENABLE
    help
      Maximum accumulated movement for the release-tap detection.

config INPUT_IQS9151_DRAG_LOCK_RELEASE_TAP_CLICK_ENABLE
    bool "IQS9151 drag lock release-tap emits a click (1F only)"
    default n
    depends on INPUT_IQS9151_DRAG_LOCK_ENABLE
    help
      When enabled, releasing a 1F drag lock with a tap also emits a
      BTN_0 click at the tap location ("drop here" semantics, similar
      to macOS trackpad). Disable to keep the release silent: useful
      when a click would deselect a multi-selection just released
      from drag, or when the user performs subsequent grab gestures
      that should not fire stray clicks. 2F/3F drag-lock releases are
      always silent regardless of this option.

config INPUT_IQS9151_3F_SWIPE_THRESHOLD
    int "IQS9151 three-finger swipe threshold"
    range 0 1000
    default 200
    help
      Three-finger swipe threshold (driver-side).

config INPUT_IQS9151_FINGER_COUNT_DEBOUNCE_ENABLE
    bool "IQS9151 finger_count debounce enable"
    default n
    help
      Filter single-frame flickers in the IC-reported finger_count
      before they reach the gesture state machines. Prevents transient
      1->2->1 or 1->3->1 jitters from spuriously triggering 2F/3F taps
      or breaking 1F TapDrag into 2F scroll. Real, sustained changes
      are propagated with at most DEBOUNCE_FRAMES-1 frames of latency.

config INPUT_IQS9151_FINGER_COUNT_DEBOUNCE_FRAMES
    int "IQS9151 finger_count debounce confirmation frames"
    range 1 5
    default 2
    depends on INPUT_IQS9151_FINGER_COUNT_DEBOUNCE_ENABLE
    help
      Number of consecutive frames a new finger_count must be observed
      before it is committed. 1 is effectively a passthrough, 2 filters
      isolated single-frame flickers, 3+ adds more latency for stricter
      filtering. Each polling cycle is one frame.

config INPUT_IQS9151_HAPTIC_FEEDBACK_ENABLE
    bool "IQS9151 haptic feedback via DRV2605L"
    default n
    depends on DRV2605
    help
      Fire DRV2605L haptic effects on gesture events (tap confirmation,
      long-press hold engagement, drag-lock arm/release). Requires both
      this option and a haptic-dev phandle on the iqs9151 devicetree node
      pointing at a DRV2605L instance. Defaults to n.

if INPUT_IQS9151_HAPTIC_FEEDBACK_ENABLE

config INPUT_IQS9151_HAPTIC_TAP_EFFECT
    int "Effect ID for tap confirmation"
    range 0 123
    default 1
    help
      DRV2605L built-in effect ID (1-123) to play when a 1F/2F/3F tap
      is confirmed. 0 disables this event. Default 1 (Strong Click 100%).
      Recommended values: 1, 2, 3 (clicks), 7-9 (soft bumps).

config INPUT_IQS9151_HAPTIC_LONG_PRESS_EFFECT
    int "Effect ID for long-press hold engagement"
    range 0 123
    default 47
    help
      Effect ID to play when long-press hold engages. 0 disables.
      Default 47 (Buzz 1 100%) gives a distinct buzz to confirm the hold
      latched. Recommended: 47-52 (buzzes), 14-16 (sharp clicks).

config INPUT_IQS9151_HAPTIC_DRAG_LOCK_ARM_EFFECT
    int "Effect ID for drag-lock arm"
    range 0 123
    default 10
    help
      Effect ID to play when drag-lock arms (TapDrag/long-press lift
      with drag-lock enabled). 0 disables. Default 10 (Double Click 100%).

config INPUT_IQS9151_HAPTIC_DRAG_LOCK_RELEASE_EFFECT
    int "Effect ID for drag-lock release"
    range 0 123
    default 7
    help
      Effect ID to play when drag-lock releases. 0 disables.
      Default 7 (Soft Bump 100%).

config INPUT_IQS9151_HAPTIC_DRAG_BUZZ_EFFECT
    int "Effect ID played repeatedly while a button is held (drag buzz)"
    range 0 123
    default 9
    help
      Effect ID to play repeatedly while hold_button is active (drag/hold).
      Default 9 (Soft Bump 30%). Set to 0 to disable drag buzz entirely.

config INPUT_IQS9151_HAPTIC_DRAG_BUZZ_INTERVAL_MS
    int "Interval between drag buzz pulses (ms)"
    range 20 500
    default 100
    help
      How often (in ms) to repeat the drag buzz effect while holding.

endif # INPUT_IQS9151_HAPTIC_FEEDBACK_ENABLE

